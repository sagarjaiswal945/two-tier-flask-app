pipeline {
    agent {
        docker {
            image 'docker:25.0.3-cli'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        IMAGE_NAME = 'sg945/flask-app'
        IMAGE_TAG  = 'latest'
        DOCKER_CONFIG = "${WORKSPACE}/.docker"
    }

    stages {

        stage('Code Checkout') {
            steps {
                git url: 'https://github.com/sagarjaiswal945/two-tier-flask-app',
                    branch: 'master'
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                  docker run --rm \
                    -v $WORKSPACE:/workspace \
                    aquasec/trivy:latest \
                    fs /workspace
                '''
            }
        }

        stage('Build Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$IMAGE_TAG .'
            }
        }

        stage('Push Image') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhubcredentials',
                        usernameVariable: 'DOCKERHUB_USERNAME',
                        passwordVariable: 'DOCKERHUB_PASSWORD'
                    )
                ]) {
                    sh '''
                      echo $DOCKERHUB_PASSWORD | docker login -u $DOCKERHUB_USERNAME --password-stdin
                      docker push $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d'
            }
        }
    }
    stage('Deploy to EKS') {
      steps {
        sh '''
        docker run --rm \
          --entrypoint /bin/sh \
          -v $WORKSPACE:/workspace \
          -v $JENKINS_HOME/.kube:/root/.kube \
          -e AWS_REGION=ap-south-1 \
          public.ecr.aws/aws-cli/aws-cli:latest -c "
    
            echo 'Using existing curl (no install needed)' && \
            curl --version && \
    
            echo 'Installing kubectl...' && \
            curl -LO https://dl.k8s.io/release/v1.29.3/bin/linux/amd64/kubectl && \
            chmod +x kubectl && mv kubectl /usr/local/bin/kubectl && \
    
            echo 'Updating kubeconfig...' && \
            aws eks update-kubeconfig \
              --region ap-south-1 \
              --name jenkis-eks-cluster && \
    
            kubectl version --client && \
            kubectl apply -f /workspace/k8s/
          "
        '''
      }
}
}
